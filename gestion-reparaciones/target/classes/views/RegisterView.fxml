<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.reparaciones.controllers.RegisterController"
            style="-fx-background-color: #001232;"
            prefWidth="700"
            prefHeight="620">

    <top>
        <VBox alignment="CENTER" spacing="14" style="-fx-background-color: #001232;">
            <padding><Insets top="32" right="48" bottom="24" left="48"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                    <image><Image url="@/images/logo.png"/></image>
                </ImageView>
                <VBox spacing="2">
                    <Label text="Gestión de usuarios"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #F6F6F6;"/>
                    <Label text="Registra o elimina accesos al sistema"
                           style="-fx-font-size: 12px; -fx-text-fill: #586376;"/>
                </VBox>
            </HBox>

            <HBox spacing="12" maxWidth="620" fillHeight="true">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Nombre del técnico" style="-fx-font-size: 12px; -fx-text-fill: #F6F6F6;"/>
                    <TextField fx:id="campoNombreTecnico"
                               promptText="Nombre visible en reparaciones"
                               style="-fx-background-color: #2C3B54; -fx-border-color: #586376; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-text-fill: #F6F6F6; -fx-prompt-text-fill: #586376;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Nombre de usuario" style="-fx-font-size: 12px; -fx-text-fill: #F6F6F6;"/>
                    <TextField fx:id="campoNombreUsuario"
                               promptText="Credencial de login"
                               style="-fx-background-color: #2C3B54; -fx-border-color: #586376; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-text-fill: #F6F6F6; -fx-prompt-text-fill: #586376;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Contraseña" style="-fx-font-size: 12px; -fx-text-fill: #F6F6F6;"/>
                    <PasswordField fx:id="campoPassword"
                                   promptText="Contraseña"
                                   style="-fx-background-color: #2C3B54; -fx-border-color: #586376; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-text-fill: #F6F6F6; -fx-prompt-text-fill: #586376;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Confirmar" style="-fx-font-size: 12px; -fx-text-fill: #F6F6F6;"/>
                    <PasswordField fx:id="campoConfirmar"
                                   promptText="Repite la contraseña"
                                   style="-fx-background-color: #2C3B54; -fx-border-color: #586376; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-text-fill: #F6F6F6; -fx-prompt-text-fill: #586376;"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="620">
                <Label fx:id="lblError"
                       text=""
                       style="-fx-text-fill: #FB8888; -fx-font-size: 12px;"
                       visible="false"
                       HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRegistrar"
                        text="Registrar técnico"
                        onAction="#registrar"
                        style="-fx-background-color: #F1E356; -fx-text-fill: #001232; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 4; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
            </HBox>

            <Separator maxWidth="620" style="-fx-background-color: #2C3B54;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-background-color: #001232;">
            <padding><Insets top="16" right="48" bottom="0" left="48"/></padding>
            <Label text="Técnicos registrados"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #F6F6F6;"/>
            <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #2C3B54; -fx-border-color: #586376;">
                <columns>
                    <TableColumn fx:id="colNombreUsuario" text="Usuario" prefWidth="200"/>
                    <TableColumn fx:id="colAcciones" text="" prefWidth="50"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-background-color: #001232;">
            <padding><Insets top="12" right="48" bottom="24" left="48"/></padding>
            <Button text="Volver al login"
                    onAction="#volverLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #586376; -fx-font-size: 12px; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>
