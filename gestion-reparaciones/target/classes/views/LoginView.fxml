<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.reparaciones.controllers.LoginController"
      alignment="CENTER"
      spacing="16"
      style="-fx-background-color: #F3F3F3;"
      prefWidth="380"
      prefHeight="480">

    <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

    <!-- Logo -->
    <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
        <image><Image url="@/images/logo.png"/></image>
    </ImageView>

    <Label text="Gestión de Reparaciones"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>

    <Label text="Inicia sesión para continuar"
           style="-fx-font-size: 12px; -fx-text-fill: #A9A9A9;"/>

    <VBox spacing="6" maxWidth="280" fillWidth="true">
        <Label text="Usuario" style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
        <TextField fx:id="campoUsuario"
                   promptText="Nombre de usuario"
                   style="-fx-background-color: white; -fx-border-color: #E7E7E7; -fx-border-radius: 2; -fx-background-radius: 2; -fx-padding: 8;"/>
    </VBox>

    <VBox spacing="6" maxWidth="280" fillWidth="true">
        <Label text="Contraseña" style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
        <PasswordField fx:id="campoPassword"
                       promptText="Contraseña"
                       style="-fx-background-color: white; -fx-border-color: #E7E7E7; -fx-border-radius: 2; -fx-background-radius: 2; -fx-padding: 8;"/>
    </VBox>

    <Label fx:id="lblError"
           text=""
           style="-fx-text-fill: #FB8888; -fx-font-size: 12px;"
           visible="false"/>

    <Button fx:id="btnLogin"
            text="Iniciar sesión"
            onAction="#login"
            maxWidth="280"
            style="-fx-background-color: #333333; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 2; -fx-padding: 10;"/>
    
    <Button text="Registrar nuevo técnico"
        onAction="#irARegistro"
        maxWidth="280"
        style="-fx-background-color: transparent; -fx-text-fill: #A9A9A9; -fx-font-size: 12px; -fx-cursor: hand;"/>

</VBox>