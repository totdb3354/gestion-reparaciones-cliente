<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.reparaciones.controllers.FormularioCompraController"
      styleClass="vista-container"
      stylesheets="@../styles/reparacion.css"
      spacing="16" prefWidth="700">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <Label fx:id="lblTitulo" text="Nuevo pedido" styleClass="vista-titulo"/>

    <!-- Cabecera: proveedor + divisa (comunes a todas las líneas) -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <Label text="Proveedor:" styleClass="form-label" minWidth="90"/>
        <ComboBox fx:id="cmbProveedor" prefWidth="220"/>
        <Label text="Divisa:" styleClass="form-label"/>
        <ComboBox fx:id="cmbDivisa" prefWidth="84"/>
        <Label fx:id="lblTasa" style="-fx-font-size:11px; -fx-text-fill:#A0A0A0;"/>
    </HBox>

    <!-- Tabla de líneas -->
    <TableView fx:id="tablaLineas" styleClass="tabla-reparaciones" VBox.vgrow="ALWAYS"
               editable="true" prefHeight="220">
        <columns>
            <TableColumn fx:id="colComponente" text="Componente"  prefWidth="240"/>
            <TableColumn fx:id="colCantidad"   text="Cant."       prefWidth="60"/>
            <TableColumn fx:id="colPrecio"     text="P.Unit."     prefWidth="90"/>
            <TableColumn fx:id="colUrgente"    text="Urg."        prefWidth="50"/>
            <TableColumn fx:id="colTotalEur"   text="Total EUR"   prefWidth="100"/>
            <TableColumn fx:id="colQuitar"     text=""            prefWidth="40"/>
        </columns>
        <placeholder><Label text="Añade al menos una línea"/></placeholder>
    </TableView>

    <Button text="+ Añadir línea" styleClass="btn-secondary" onAction="#anadirLinea"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar"  styleClass="btn-secondary" onAction="#cancelar"/>
        <Button fx:id="btnConfirmar" text="Confirmar pedido" styleClass="btn-primary" onAction="#confirmar"/>
    </HBox>

</VBox>
