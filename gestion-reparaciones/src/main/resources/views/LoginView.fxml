<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.reparaciones.controllers.LoginController"
      alignment="CENTER"
      spacing="16"
      style="-fx-background-color: #001232;"
      prefWidth="380"
      prefHeight="480">

    <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

    <!-- Logo -->
    <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
        <image><Image url="@/images/logo.png"/></image>
    </ImageView>

    <Label text="Gestión de Reparaciones"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #F6F6F6;"/>

    <Label text="Inicia sesión para continuar"
           style="-fx-font-size: 12px; -fx-text-fill: #586376;"/>

    <VBox spacing="6" maxWidth="280" fillWidth="true">
        <Label text="Usuario" style="-fx-font-size: 12px; -fx-text-fill: #F6F6F6;"/>
        <TextField fx:id="campoUsuario"
                   promptText="Nombre de usuario"
                   style="-fx-background-color: #2C3B54; -fx-border-color: #586376; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-text-fill: #F6F6F6; -fx-prompt-text-fill: #586376;"/>
    </VBox>

    <VBox spacing="6" maxWidth="280" fillWidth="true">
        <Label text="Contraseña" style="-fx-font-size: 12px; -fx-text-fill: #F6F6F6;"/>
        <PasswordField fx:id="campoPassword"
                       promptText="Contraseña"
                       style="-fx-background-color: #2C3B54; -fx-border-color: #586376; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-text-fill: #F6F6F6; -fx-prompt-text-fill: #586376;"/>
    </VBox>

    <Label fx:id="lblError"
           text=""
           style="-fx-text-fill: #FB8888; -fx-font-size: 12px;"
           visible="false"/>

    <Button fx:id="btnLogin"
            text="Iniciar sesión"
            onAction="#login"
            maxWidth="280"
            style="-fx-background-color: #F1E356; -fx-text-fill: #001232; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 4; -fx-padding: 10; -fx-cursor: hand;"/>

    <Button text="Registrar nuevo técnico"
        onAction="#irARegistro"
        maxWidth="280"
        style="-fx-background-color: transparent; -fx-text-fill: #586376; -fx-font-size: 12px; -fx-cursor: hand;"/>

</VBox>
