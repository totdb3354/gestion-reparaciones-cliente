<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.reparaciones.controllers.StockController"
            styleClass="vista-container"
            stylesheets="@../styles/app.css">

    <!-- ── Sidebar ──────────────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="stock-sidebar" spacing="0">
            <Button fx:id="btnTabStock"       text="Stock actual"  maxWidth="Infinity"
                    styleClass="stock-sidebar-btn-active" onAction="#mostrarTabStock"/>
            <Button fx:id="btnTabPedidos"     text="Pedidos"       maxWidth="Infinity"
                    styleClass="stock-sidebar-btn"        onAction="#mostrarTabPedidos"/>
            <Button fx:id="btnTabProveedores" text="Proveedores"   maxWidth="Infinity"
                    styleClass="stock-sidebar-btn"        onAction="#mostrarTabProveedores"/>
        </VBox>
    </left>

    <!-- ── Contenido ────────────────────────────────────────────────────────── -->
    <center>
        <StackPane>
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- ══ Panel: Stock actual ══════════════════════════════════════════ -->
            <VBox fx:id="pnlStock" spacing="12" visible="true" managed="true">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Stock actual" styleClass="vista-titulo" HBox.hgrow="ALWAYS"/>
                    <MenuButton fx:id="menuFiltroStock" text="Estado" prefWidth="130"/>
                    <TextField fx:id="txtBuscador" promptText="Buscar componente…"
                               styleClass="buscador" prefWidth="220"/>
                    <Button fx:id="btnLimpiarFiltrosStock" text="Limpiar filtros"
                            styleClass="btn-secondary" onAction="#limpiarFiltrosStock"/>
                </HBox>
                <HBox spacing="16" VBox.vgrow="ALWAYS">
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                    <TableView fx:id="tablaStock" styleClass="tabla-reparaciones" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTipo"        text="Componente"   prefWidth="230"/>
                            <TableColumn fx:id="colStockVal"   text="En Stock"     prefWidth="80"/>
                            <TableColumn fx:id="colEnCamino"   text="En Camino"    prefWidth="90"/>
                            <TableColumn fx:id="colStockMin"   text="Stock Mínimo" prefWidth="100"/>
                            <TableColumn fx:id="colUltimoPed"  text="Último pedido" prefWidth="120"/>
                            <TableColumn fx:id="colEstado"     text="Estado"       prefWidth="100"/>
                        </columns>
                        <placeholder><Label text="Sin componentes"/></placeholder>
                    </TableView>
                    <Label fx:id="lblUltimaActStock"
                           style="-fx-font-size: 10px; -fx-text-fill: #A0A0A0;"
                           alignment="CENTER_RIGHT" maxWidth="Infinity"/>
                    </VBox>
                    <VBox fx:id="pnlChart" spacing="0" prefWidth="240" minWidth="240"
                          style="-fx-background-color:white; -fx-background-radius:6;
                                 -fx-border-color:#C2C8D0; -fx-border-radius:6; -fx-padding:16;">
                        <!-- Mitad superior: tarta -->
                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <Label text="Estado del stock"
                                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#2C3B54;"/>
                            <PieChart fx:id="chartEstado" labelsVisible="false"
                                      legendVisible="false" animated="false"
                                      VBox.vgrow="ALWAYS"/>
                            <HBox fx:id="pnlLeyenda" spacing="8"/>
                        </VBox>
                        <Separator style="-fx-padding: 4 0 4 0;"/>
                        <!-- Mitad inferior: barras por SKU -->
                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <Label fx:id="lblChartSku"
                                   text="Selecciona un componente"
                                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#2C3B54;"/>
                            <StackPane VBox.vgrow="ALWAYS">
                                <Label fx:id="lblPlaceholder" text="↑ Haz clic en una fila"
                                       style="-fx-text-fill:#A9A9A9; -fx-font-size:11px;"
                                       visible="true" managed="true"/>
                                <BarChart fx:id="chartSku" animated="false"
                                          legendVisible="false" visible="false" managed="false">
                                    <xAxis><CategoryAxis fx:id="chartSkuX"/></xAxis>
                                    <yAxis><NumberAxis fx:id="chartSkuY" label="Unidades" tickUnit="1" minorTickCount="0"/></yAxis>
                                </BarChart>
                            </StackPane>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ══ Panel: Pedidos ═══════════════════════════════════════════════ -->
            <VBox fx:id="pnlPedidos" spacing="12" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Pedidos" styleClass="vista-titulo" HBox.hgrow="ALWAYS"/>
                    <MenuButton fx:id="menuFiltroEstado" text="Estado" prefWidth="140"/>
                    <TextField fx:id="txtBuscadorPedidos" promptText="Buscar componente…"
                               styleClass="buscador" prefWidth="200"/>
                    <Button fx:id="btnLimpiarFiltrosPedidos" text="Limpiar filtros"
                            styleClass="btn-secondary" onAction="#limpiarFiltrosPedidos"/>
                    <Button fx:id="btnNuevoPedido" text="Nuevo pedido" styleClass="btn-primary" onAction="#nuevoPedido"/>
                </HBox>
                <TableView fx:id="tablaPedidos" styleClass="tabla-reparaciones" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="cpFecha"      text="Pedido"     prefWidth="115"/>
                        <TableColumn fx:id="cpComponente" text="Componente" prefWidth="190"/>
                        <TableColumn fx:id="cpProveedor"  text="Proveedor"  prefWidth="130"/>
                        <TableColumn fx:id="cpCantidad"   text="Cant."      prefWidth="50"/>
                        <TableColumn fx:id="cpPrecio"     text="P.Unit."    prefWidth="68"/>
                        <TableColumn fx:id="cpDivisa"     text="Div."       prefWidth="45"/>
                        <TableColumn fx:id="cpEur"        text="EUR"        prefWidth="68"/>
                        <TableColumn fx:id="cpEstado"     text="Estado"     prefWidth="110"/>
                        <TableColumn fx:id="cpId"         text="ID"         prefWidth="50" visible="false"/>
                    </columns>
                    <placeholder><Label text="Sin pedidos"/></placeholder>
                </TableView>
                <Label fx:id="lblUltimaActPedidos"
                       style="-fx-font-size: 10px; -fx-text-fill: #A0A0A0;"
                       alignment="CENTER_RIGHT" maxWidth="Infinity"/>
            </VBox>

            <!-- ══ Panel: Proveedores ═══════════════════════════════════════════ -->
            <VBox fx:id="pnlProveedores" spacing="12" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Proveedores" styleClass="vista-titulo" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnNuevoProveedor" text="Nuevo proveedor" styleClass="btn-primary" onAction="#nuevoProveedor"/>
                </HBox>
                <TableView fx:id="tablaProveedores" styleClass="tabla-reparaciones" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="cpvNombre" text="Nombre" prefWidth="300"/>
                        <TableColumn fx:id="cpvActivo" text="Estado"  prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="Sin proveedores"/></placeholder>
                </TableView>
                <Label fx:id="lblUltimaActProveedores"
                       style="-fx-font-size: 10px; -fx-text-fill: #A0A0A0;"
                       alignment="CENTER_RIGHT" maxWidth="Infinity"/>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
