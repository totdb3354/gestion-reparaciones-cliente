<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.reparaciones.controllers.RegisterController"
            style="-fx-background-color: #EFEFEF;"
            prefWidth="700"
            prefHeight="620">

    <top>
        <VBox spacing="16" style="-fx-background-color: #EFEFEF;">
            <padding><Insets top="28" right="48" bottom="20" left="48"/></padding>

            <!-- Cabecera -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <ImageView fitWidth="46" fitHeight="46" preserveRatio="true">
                    <image><Image url="@/images/logo_inicio_sesion.png"/></image>
                </ImageView>
                <VBox spacing="2">
                    <Label text="Gestión de usuarios"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3B54;"/>
                    <Label text="Registra o elimina accesos al sistema"
                           style="-fx-font-size: 12px; -fx-text-fill: #586376;"/>
                </VBox>
            </HBox>

            <!-- Campos del formulario -->
            <HBox spacing="12" fillHeight="true">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nombre del técnico"
                           style="-fx-font-size: 11px; -fx-text-fill: #586376; -fx-font-weight: bold;"/>
                    <TextField fx:id="campoNombreTecnico"
                               promptText="Nombre visible en reparaciones"
                               style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 10 12 10 12; -fx-font-size: 13px;
                                      -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nombre de usuario"
                           style="-fx-font-size: 11px; -fx-text-fill: #586376; -fx-font-weight: bold;"/>
                    <TextField fx:id="campoNombreUsuario"
                               promptText="Credencial de login"
                               style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 10 12 10 12; -fx-font-size: 13px;
                                      -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Contraseña"
                           style="-fx-font-size: 11px; -fx-text-fill: #586376; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="campoPassword"
                                   promptText="Contraseña"
                                   style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 12 10 12; -fx-font-size: 13px;
                                          -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Confirmar"
                           style="-fx-font-size: 11px; -fx-text-fill: #586376; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="campoConfirmar"
                                   promptText="Repite la contraseña"
                                   style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 12 10 12; -fx-font-size: 13px;
                                          -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;"/>
                </VBox>
            </HBox>

            <!-- Error + botón -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="lblError" text=""
                       style="-fx-text-fill: #B03040; -fx-font-size: 11px;"
                       visible="false" HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRegistrar"
                        text="Registrar técnico"
                        onAction="#registrar"
                        style="-fx-background-color: #001232; -fx-text-fill: #F6F6F6;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 24; -fx-padding: 10 24 10 24;
                               -fx-cursor: hand;"/>
            </HBox>

            <Separator style="-fx-background-color: #D4D8DE;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-background-color: #EFEFEF;">
            <padding><Insets top="16" right="48" bottom="0" left="48"/></padding>
            <Label text="Técnicos registrados"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3B54;"/>
            <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS" styleClass="tabla-reparaciones"
                       stylesheets="@../styles/app.css">
                <columns>
                    <TableColumn fx:id="colNombreTecnico"  text="Técnico"  prefWidth="180"/>
                    <TableColumn fx:id="colNombreUsuario"  text="Usuario"  prefWidth="160"/>
                    <TableColumn fx:id="colEstado"         text="Estado"   prefWidth="100"/>
                    <TableColumn fx:id="colAcciones"       text=""         prefWidth="80"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-background-color: #EFEFEF;">
            <padding><Insets top="12" right="48" bottom="20" left="48"/></padding>
            <Button text="Cerrar"
                    onAction="#cerrar"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-text-fill: #586376; -fx-font-size: 12px; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>
