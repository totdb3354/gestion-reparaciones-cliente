<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.reparaciones.utils.MultiSelectComboBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/25"
      fx:controller="com.reparaciones.controllers.PendientesSuperTecnicoController"
      spacing="12" VBox.vgrow="ALWAYS"
      stylesheets="@../styles/app.css">

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Asignaciones pendientes" styleClass="vista-titulo"/>
        <Label fx:id="lblContador" style="-fx-background-color: #E8EAF0; -fx-text-fill: #586376; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 12; -fx-padding: 3 10 3 10;"/>
        <TextField fx:id="filtroImei" promptText="Filtrar por IMEI" prefWidth="160" styleClass="buscador"/>
        <com.reparaciones.utils.MultiSelectComboBox fx:id="filtroTecnico" prefWidth="130"/>
        <MenuButton fx:id="filtroSolicitud" text="Tipo"    prefWidth="130"/>
        <Button onAction="#limpiarFiltros" text="Limpiar filtros" styleClass="btn-secondary"/>
        <Button fx:id="btnAsignar"
                text="Asignar reparación"
                onAction="#abrirFormularioAsignacion"
                styleClass="btn-primary"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <TableView fx:id="tablaPendientes" styleClass="tabla-reparaciones" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="cId"      text="Id Asignación"    prefWidth="90"/>
            <TableColumn fx:id="cTecnico" text="Técnico"          prefWidth="110"/>
            <TableColumn fx:id="cImei"    text="IMEI"             prefWidth="130"/>
            <TableColumn fx:id="cModelo"  text="Modelo"           prefWidth="120"/>
            <TableColumn fx:id="cFecha"      text="Fecha asignación" prefWidth="130"/>
            <TableColumn fx:id="cComentario" text="Comentario"       prefWidth="160"/>
            <TableColumn fx:id="cCliente" text="Cliente"          prefWidth="110"/>
            <TableColumn fx:id="cAsignadoPor" text="Asignado por"    prefWidth="120"/>
            <TableColumn fx:id="cEstado"     text="Estado"           prefWidth="100"/>
            <TableColumn fx:id="cAccion"  text=""                 prefWidth="45"/>
        </columns>
        <placeholder><Label text="No hay asignaciones pendientes"/></placeholder>
    </TableView>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Label fx:id="lblUltimaActualizacion"
               style="-fx-font-size: 10px; -fx-text-fill: #A0A0A0;"
               HBox.hgrow="ALWAYS"/>
    </HBox>

</VBox>
