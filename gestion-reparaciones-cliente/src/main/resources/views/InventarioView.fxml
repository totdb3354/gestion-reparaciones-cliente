<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="vista-container" stylesheets="@../styles/app.css"
            xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25"
            fx:controller="com.reparaciones.controllers.InventarioController">

    <!-- ── Sidebar ── -->
    <left>
        <VBox styleClass="stock-sidebar" spacing="0">
            <Button fx:id="btnTabInventario" text="Inventario" maxWidth="Infinity"
                    styleClass="stock-sidebar-btn-active" onAction="#mostrarInventarioPanel"/>
            <Button fx:id="btnTabSuppliers"  text="Suppliers"  maxWidth="Infinity"
                    styleClass="stock-sidebar-btn" onAction="#mostrarSuppliers"/>
        </VBox>
    </left>

    <!-- ── Contenido ── -->
    <center>
        <StackPane>

            <!-- Panel: Inventario (agrupado por IMEI, componente compartido) -->
            <VBox fx:id="pnlInventario" visible="true" managed="true" VBox.vgrow="ALWAYS">
                <fx:include source="AgrupadoView.fxml" fx:id="agrupado"/>
            </VBox>

            <!-- Panel: Suppliers (proveedores de teléfonos — calco del panel Proveedores de Stock) -->
            <VBox fx:id="pnlSuppliers" spacing="12" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Suppliers" styleClass="vista-titulo"/>
                </HBox>
                <FlowPane hgap="12" vgap="6" alignment="CENTER_LEFT">
                    <Button fx:id="btnNuevoSupplier" text="Nuevo supplier" styleClass="btn-primary" onAction="#nuevoSupplier"/>
                </FlowPane>
                <TableView fx:id="tablaSuppliers" styleClass="tabla-reparaciones" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="cspNombre"     text="Nombre"     prefWidth="200"/>
                        <TableColumn fx:id="cspDivisa"     text="Divisa"     prefWidth="60"/>
                        <TableColumn fx:id="cspActivo"     text="Estado"     prefWidth="90"/>
                        <TableColumn fx:id="cspComentario" text="Comentario" prefWidth="300"/>
                    </columns>
                    <placeholder><Label text="Sin suppliers"/></placeholder>
                </TableView>
                <Label fx:id="lblUltimaActSuppliers"
                       style="-fx-font-size: 10px; -fx-text-fill: #A0A0A0;"
                       alignment="CENTER_RIGHT" maxWidth="Infinity"/>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
