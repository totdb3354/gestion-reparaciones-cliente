<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.reparaciones.controllers.LoginController"
           style="-fx-background-color: #EFEFEF;"
           prefWidth="420"
           prefHeight="540">

    <VBox alignment="CENTER" spacing="0" maxWidth="340" StackPane.alignment="CENTER">

        <!-- Logo -->
        <ImageView fitWidth="58" fitHeight="58" preserveRatio="true">
            <image><Image url="@/images/logo_inicio_sesion.png"/></image>
            <VBox.margin><Insets bottom="14"/></VBox.margin>
        </ImageView>

        <!-- Título -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="FSGR"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3B54;"/>
            <Label text="v0.4.0"
                   style="-fx-font-size: 11px; -fx-text-fill: #A0A8B4; -fx-padding: 5 0 0 0;"/>
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </HBox>

        <!-- Subtítulo -->
        <VBox alignment="CENTER" spacing="0">
            <VBox.margin><Insets bottom="32"/></VBox.margin>
            <Label text="Gestión de Stock y"
                   style="-fx-font-size: 20px; -fx-text-fill: #2C3B54;"
                   alignment="CENTER" textAlignment="CENTER"/>
            <Label text="Reparaciones"
                   style="-fx-font-size: 20px; -fx-text-fill: #2C3B54;"
                   alignment="CENTER" textAlignment="CENTER"/>
        </VBox>

        <!-- Campo Usuario -->
        <TextField fx:id="campoUsuario"
                   promptText="Usuario"
                   maxWidth="Infinity"
                   style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 13 14 13 14; -fx-font-size: 13px;
                          -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </TextField>

        <!-- Campo Contraseña con toggle ojo -->
        <StackPane maxWidth="Infinity">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
            <PasswordField fx:id="campoPassword"
                           promptText="Contraseña"
                           style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 13 44 13 14; -fx-font-size: 13px;
                                  -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;"/>
            <TextField fx:id="campoPasswordVisible"
                       promptText="Contraseña"
                       visible="false" managed="false"
                       style="-fx-background-color: white; -fx-border-color: #D4D8DE;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 13 44 13 14; -fx-font-size: 13px;
                              -fx-text-fill: #2C3B54; -fx-prompt-text-fill: #A0A8B4;"/>
            <Button fx:id="btnTogglePassword"
                    onAction="#togglePassword"
                    StackPane.alignment="CENTER_RIGHT"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-cursor: hand; -fx-padding: 0 12 0 0;">
                <graphic>
                    <ImageView fx:id="imgOjo" fitWidth="18" fitHeight="18" preserveRatio="true">
                        <image><Image url="@/images/ojo_activar.png"/></image>
                    </ImageView>
                </graphic>
            </Button>
        </StackPane>

        <!-- Error -->
        <Label fx:id="lblError" text=""
               style="-fx-text-fill: #B03040; -fx-font-size: 11px;"
               visible="false" wrapText="true" maxWidth="Infinity">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Label>

        <!-- Botón Iniciar Sesión -->
        <Button fx:id="btnLogin"
                text="Iniciar Sesión"
                onAction="#login"
                maxWidth="Infinity"
                style="-fx-background-color: #001232; -fx-text-fill: #F6F6F6;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-background-radius: 24; -fx-padding: 14 0 14 0;
                       -fx-cursor: hand;">
            <VBox.margin><Insets top="18" bottom="14"/></VBox.margin>
        </Button>

    </VBox>

</StackPane>
